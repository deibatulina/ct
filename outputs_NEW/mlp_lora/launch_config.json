{
  "experiment_name": "mlp_lora",
  "data": {
    "train_path": "data/preprocessing/train.json",
    "val_path": "data/preprocessing/val.json",
    "test_path": "data/preprocessing/test.json",
    "input_mode": "multi_slice",
    "num_slices": 8,
    "image_size": 224,
    "max_text_length": 256,
    "prompt_template": "Lung findings:"
  },
  "model": {
    "visual_encoder_name": "resnet18",
    "language_model_name": "openai-community/gpt2",
    "visual_feature_dim": 512,
    "mlp_hidden_dim": 1024,
    "mlp_dropout": 0.1,
    "lm_hidden_dim": 768,
    "visual_prefix_tokens": 8,
    "aggregation": "mean",
    "projection_type": "mlp_lora",
    "num_anatomy_labels": 1,
    "use_anatomy_embedding": false,
    "use_slice_position_embedding": true,
    "freeze_visual_encoder": true,
    "freeze_language_model": true
  },
  "training": {
    "seed": 42,
    "batch_size": 4,
    "gradient_accumulation_steps": 2,
    "num_epochs": 10,
    "learning_rate": 5e-05,
    "bridge_learning_rate": 0.0001,
    "lora_learning_rate": 5e-05,
    "weight_decay": 0.01,
    "warmup_ratio": 0.1,
    "max_grad_norm": 1.0,
    "label_smoothing": 0.0,
    "sampling_strategy": "anatomy_text_balanced",
    "early_stopping_metric": "rougeL"
  },
  "generation": {
    "max_new_tokens": 96,
    "do_sample": false,
    "num_beams": 1,
    "repetition_penalty": 1.1,
    "no_repeat_ngram_size": 4
  },
  "lora": {
    "enabled": true,
    "r": 8,
    "alpha": 16,
    "dropout": 0.05,
    "bias": "none",
    "task_type": "CAUSAL_LM",
    "target_modules": [
      "attn.c_attn",
      "attn.c_proj"
    ],
    "fan_in_fan_out": true
  },
  "outputs": {
    "root_dir": "outputs/mlp_lora"
  }
}
